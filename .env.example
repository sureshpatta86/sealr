# ─── SQL Server 2022 ──────────────────────
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_DB=sealr
SQL_SERVER_USER=sa
SQL_SERVER_PASSWORD=Sealr@Dev123

# ─── Redis ────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── AI Models ────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4
OPENAI_THINKING_MODEL=gpt-5.4-thinking
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6

# ─── Security ─────────────────────────────
ENCRYPTION_KEY=your-32-byte-base64-encoded-key
JWT_SECRET=your-jwt-secret-here

# ─── GitHub ───────────────────────────────
GITHUB_API_BASE=https://api.github.com
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ─── Docker ──────────────────────────────
DOCKER_HOST=unix:///var/run/docker.sock

# ─── Frontend ─────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── S3 / MinIO ──────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sealr
S3_SECRET_KEY=sealr123
S3_BUCKET=sealr-scans

# ─── Logging ──────────────────────────────
LOG_LEVEL=info

# ─── Infrastructure ───────────────────────
# Set to true to auto-start Docker infra (SQL Server, Redis, MinIO) via docker-compose.
# Set to false if you're managing infra externally (remote DB, cloud Redis, etc.).
USE_LOCAL_INFRA=true
